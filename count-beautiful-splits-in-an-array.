class Solution:
    def beautifulSplits(self, nums: List[int]) -> int:
        n = len(nums)
        mod = 10**9 + 7
        base = 91138233
        pow_base = [1] * (n + 1)
        for i in range(1, n + 1):
            pow_base[i] = (pow_base[i - 1] * base) % mod
        pref = [0] * (n + 1)
        for i in range(n):
            pref[i + 1] = (pref[i] * base + nums[i] + 1) % mod
        def sub_hash(l, r):
            return (pref[r] - pref[l] * pow_base[r - l]) % mod
        count = 0
        for i in range(1, n - 1):
            for j in range(i + 1, n):
                len1 = i
                len2 = j - i
                len3 = n - j
                if len1 <= len2:
                    if sub_hash(0, len1) == sub_hash(i, i + len1):
                        count += 1
                        continue
                if len2 <= len3:
                    if sub_hash(i, j) == sub_hash(j, j + len2):
                        count += 1
        return count

