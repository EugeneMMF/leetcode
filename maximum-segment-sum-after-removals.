class Solution:
    def maximumSegmentSum(self, nums: List[int], removeQueries: List[int]) -> List[int]:
        n = len(nums)
        parent = list(range(n))
        size = [0] * n
        comp_sum = [0] * n
        active = [False] * n

        def find(x):
            while parent[x] != x:
                parent[x] = parent[parent[x]]
                x = parent[x]
            return x

        def union(a, b):
            ra, rb = find(a), find(b)
            if ra == rb:
                return
            if size[ra] < size[rb]:
                ra, rb = rb, ra
            parent[rb] = ra
            size[ra] += size[rb]
            comp_sum[ra] += comp_sum[rb]

        answer_rev = [0] * n
        max_sum = 0
        for idx in range(n - 1, -1, -1):
            i = removeQueries[idx]
            active[i] = True
            parent[i] = i
            size[i] = 1
            comp_sum[i] = nums[i]
            if i > 0 and active[i - 1]:
                union(i, i - 1)
            if i + 1 < n and active[i + 1]:
                union(i, i + 1)
            root = find(i)
            max_sum = max(max_sum, comp_sum[root])
            answer_rev[idx] = max_sum
        return answer_rev[1:] + [0]

