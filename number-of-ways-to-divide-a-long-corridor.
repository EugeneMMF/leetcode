class Solution:
    def numberOfWays(self, corridor: str) -> int:
        MOD = 10**9 + 7
        seats = [i for i, ch in enumerate(corridor) if ch == 'S']
        if len(seats) % 2 == 1:
            return 0
        if not seats:
            return 0
        ways = 1
        for i in range(0, len(seats), 2):
            if i + 2 >= len(seats):
                break
            diff = seats[i + 2] - seats[i + 1]
            ways = (ways * diff) % MOD
        return ways

